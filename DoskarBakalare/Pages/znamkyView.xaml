<Page x:Class="DoskarBakalare.Pages.znamkyView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DoskarBakalare.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="znamkyView">

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="51*"/>
            <ColumnDefinition Width="29*"/>
        </Grid.ColumnDefinitions>
        <ListView Background="#FF02023C" Grid.Column="0" Name="ZnamkyHolder" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Foreground="White">
            <ListView.View>
                <GridView >
                    <GridViewColumn Header="Znamka" Width="100" DisplayMemberBinding="{Binding Hodnota}">
                    </GridViewColumn>
                    <GridViewColumn Header="Vaha" Width="100" DisplayMemberBinding="{Binding Vaha}">
                    </GridViewColumn>
                    <GridViewColumn Header="Tema" Width="200" DisplayMemberBinding="{Binding Popis}">
                    </GridViewColumn>
                    <GridViewColumn Header="Datum" Width="100" DisplayMemberBinding="{Binding Date}">
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>


        <Border BorderBrush="AliceBlue" BorderThickness="3" Grid.Column="1" Height="156" VerticalAlignment="Top">
            <StackPanel>
                
                <Button Content="Pridat Znamku"  Height="50" Click="PridatZnamku" Grid.Column="1"/>
                <Button Content="Odebrat Znamku" Height="50" Click="OdebratZnamku" Grid.Column="1"/>
                <Button Content="Upravit Znamku"  Height="50" Click="UpravitZnamku" Grid.Column="1"/>
                
            </StackPanel>
        </Border>




        <TextBlock Text="Id predmetu" Grid.Column="1" VerticalAlignment="Bottom"  HorizontalAlignment="Left" Margin="10,0,10,40" Foreground="White"/>
        <TextBox Text="{Binding IdPredmetu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" VerticalAlignment="Bottom" Margin="10,0,10,10" Width="30" TextAlignment="Center" HorizontalAlignment="Left" Foreground="White"/>
        <TextBlock Text="Pocet znamek v predmetu: " Grid.Column="1" VerticalAlignment="Bottom" Margin="80,0,10,10" Width="150" TextAlignment="Center" Name="PocetZnamek" Foreground="White"/>
        
        <TextBlock Text="{Binding Prumer, Mode=OneWay}" Grid.Column="1" VerticalAlignment="Bottom" Margin="80,0,10,40" Width="200" TextAlignment="Center" Name="PrumerZnamek" Foreground="White"/>


    </Grid>
</Page>
