<Page x:Class="DoskarBakalare.Pages.znamkyView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DoskarBakalare.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="znamkyView">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="51*"/>
            <ColumnDefinition Width="29*"/>
        </Grid.ColumnDefinitions>
        <ListView Background="LightCyan" Grid.Column="0" Name="ZnamkyHolder">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Znamka" Width="100" DisplayMemberBinding="{Binding Hodnota}">
                    </GridViewColumn>
                    <GridViewColumn Header="Vaha" Width="100" DisplayMemberBinding="{Binding Vaha}">
                    </GridViewColumn>
                    <GridViewColumn Header="Tema" Width="200" DisplayMemberBinding="{Binding Popis}">
                    </GridViewColumn>
                    <GridViewColumn Header="Datum" Width="100" DisplayMemberBinding="{Binding Datum}">
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Column="1">
            <Button Content="Pridat Znamku" Width="150" Height="50" Click="PridatZnamku"/>
            <Button Content="Odebrat Znamku" Width="150" Height="50" Click="OdebratZnamku"/>
            <Button Content="Upravit Znamku" Width="150" Height="50" Click="UpravitZnamku"/>
        </StackPanel>


    </Grid>
</Page>
