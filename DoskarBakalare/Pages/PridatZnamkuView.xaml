<Page x:Class="DoskarBakalare.Pages.PridatZnamkuView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DoskarBakalare.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PridatZnamkuView">

    <Grid Background="AntiqueWhite">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150*"/>
            <ColumnDefinition Width="100*"/>
            <ColumnDefinition Width="250*"/>
            <ColumnDefinition Width="200*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="128*"/>
            <RowDefinition Height="323*"/>
        </Grid.RowDefinitions>
        
        <Button Width="50" Height="50" Content="&lt;-" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="25" Click="Return"/>

        <TextBlock Text="Znamka" Grid.Row="0" Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="20,0,10,0"/>
        <TextBox Grid.Row="1" Grid.Column="0" Height="50" Margin="20,10,10,0" VerticalAlignment="Top" FontSize="25" Name="hodnota"/>
        
        <TextBlock Text="Vaha" Grid.Row="0" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" Height="50" Margin="10,10,10,0" VerticalAlignment="Top" FontSize="25" Name="vaha"/>
        
        <TextBlock Text="Téma" Grid.Row="0" Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="2" Height="50" Margin="10,10,10,0" VerticalAlignment="Top" FontSize="15" Name="tema"/>

        <TextBlock Text="Datum" Grid.Row="0" Grid.Column="3" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        <DatePicker Grid.Row="1" Grid.Column="3" Height="150" VerticalAlignment="Top" Margin="10,10,10,0"/>

    </Grid>
</Page>
